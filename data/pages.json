      "testimonials": [
        {
          "author": "Elizabeth R.",
          "testimonial": "“A large, modern, welcoming and bright space that is children and adult friendly. Staff is very polite and responsive. Dr. DeRose is very approachable, accessible and has very good interpersonal skills. Highly recommend this team for all your orthodontic needs.”"
        },
        {
          "author": "Radiance Y.",
          "testimonial": "“Going here to see Dr. DeRose for your goals will be one of the best decisions you ever make. I am so happy with my results!”"
        },
        {
          "author": "Meghan L.",
          "testimonial": "“Dr. De Rose and the staff are wonderful and so friendly! My son is very anxious and they put him at ease right away and made him feel so comfortable. They are also going above and beyond to keep their patients safe.”"
        },
        {
          "author": "Steven H.",
          "testimonial": "“I would highly recommend Lakeshore Orthodontics. It is worth the drive! We are extremely pleased with our experience. Treatment plan with easy monthly payments was ideal.”"
        },
        {
          "author": "Jennifer T.",
          "testimonial": "“We only have positive things to say over the years. When we first found out our daughter needed treatment it was daunting to us. The team made the entire process comfortable and easy to understand.”"
        },
        {
          "author": "LeeAnn H.",
          "testimonial": "“Dr. De Rose is amazing with my son. She takes the time to answer any questions or concerns he has about his treatment. Her professionalism and patience is appreciated and makes our experience very pleasant.”"
        }
      ],
